#!/bin/sh

set -e

CC="$ROOT_DIR/usr/local/bin/gcc"
GCC_VERSION=3.3
SRC=/tmp/pkg-gcc33-$$.c
BIN=/tmp/pkg-gcc33-$$
OBJC_SRC=/tmp/pkg-gcc33-$$.m
OBJC_BIN=/tmp/pkg-gcc33-objc-$$
OBJC_LOG=/tmp/pkg-gcc33-objc-$$.log

[ -x "$CC" ]
/bin/rm -f "$SRC" "$BIN" "$OBJC_SRC" "$OBJC_BIN" "$OBJC_LOG"

cat > "$SRC" <<'EOF'
#include <stdio.h>

int main(void)
{
    puts("ok");
    return 0;
}
EOF

"$CC" -Werror "$SRC" -o "$BIN"
value=`"$BIN"`
[ "$value" = ok ]

cat > "$OBJC_SRC" <<'EOF'
#import <Foundation/Foundation.h>

int main(void)
{
    NSAutoreleasePool *pool = [[NSAutoreleasePool alloc] init];
    NSLog(@"gcc33 Foundation ok");
    [pool release];
    return 0;
}
EOF

"$CC" "$OBJC_SRC" -o "$OBJC_BIN" -framework Foundation
"$OBJC_BIN" > "$OBJC_LOG" 2>&1
grep 'gcc33 Foundation ok' "$OBJC_LOG" >/dev/null 2>&1

if /bin/nm "$CC" | grep '___umoddi3' >/dev/null 2>&1; then
    echo "gcc driver still contains 64-bit modulo helper"
    exit 1
fi

COLLECT2="$ROOT_DIR/usr/local/lib/gcc-lib/i386-next-openstep4/$GCC_VERSION/collect2"
if [ -f "$COLLECT2" ] && /bin/nm "$COLLECT2" | grep '___umoddi3' >/dev/null 2>&1; then
    echo "collect2 still contains 64-bit modulo helper"
    exit 1
fi

/bin/rm -f "$SRC" "$BIN" "$OBJC_SRC" "$OBJC_BIN" "$OBJC_LOG"
