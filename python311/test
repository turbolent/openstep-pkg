#!/bin/sh

set -e

/usr/local/bin/python3.11 -E - <<'PY'
import decimal
import hashlib
import math
import pathlib
import socket
import subprocess
import sys
import tempfile
import zlib
import select
import xml.parsers.expat


def check(name, actual, expected):
    if actual != expected:
        print("%s mismatch: got %r, expected %r" % (name, actual, expected))
        sys.exit(1)


check("major.minor", sys.version_info[:2], (3, 11))
check("platform", sys.platform, "openstep")
check("math.sqrt", math.sqrt(81.0), 9.0)
check("zlib roundtrip", zlib.decompress(zlib.compress(b"ok")), b"ok")
check("sha256 prefix", hashlib.sha256(b"x").hexdigest()[:8], "2d711642")
check("decimal addition", decimal.Decimal("1.25") + decimal.Decimal("2.75"),
      decimal.Decimal("4.00"))
check("subprocess", subprocess.check_output(
    ["/bin/echo", "child-ok"]).decode().strip(), "child-ok")

hostname = socket.gethostname()
if not hostname:
    print("socket.gethostname returned an empty value")
    sys.exit(1)

cwd = pathlib.Path(".").resolve()
if not str(cwd).startswith("/"):
    print("pathlib resolve did not return an absolute path: %r" % (str(cwd),))
    sys.exit(1)

tmpdir = tempfile.mkdtemp(prefix="py311-test-")
if not pathlib.Path(tmpdir).is_dir():
    print("tempfile.mkdtemp did not create a directory: %r" % (tmpdir,))
    sys.exit(1)

print("python311 package smoke ok")
PY
