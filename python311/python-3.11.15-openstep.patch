+NEXT_LIBM_BINARY(fmod, "_fmod")
+NEXT_LIBM_BINARY(hypot, "_hypot")
+NEXT_LIBM_UNARY(log, "_log")
+NEXT_LIBM_UNARY(log10, "_log10")
