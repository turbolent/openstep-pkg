+#ifdef NeXT
+#ifndef INET_ADDRSTRLEN
+#define INET_ADDRSTRLEN 16
+#endif
+#ifndef INET6_ADDRSTRLEN
+#define INET6_ADDRSTRLEN 46
+#endif
+
+static int
+next_inet_pton(int af, const char *src, void *dst)
+{
+    unsigned long addr;
+
+    if (af != AF_INET) {
+        return -1;
+    }
+    addr = inet_addr(src);
+    if (addr == (unsigned long)-1) {
+        return 0;
+    }
+    memcpy(dst, &addr, sizeof(addr));
+    return 1;
+}
+
+static const char *
+next_inet_ntop(int af, const void *src, char *dst, size_t size)
+{
+    struct in_addr addr;
+    char *text;
+    size_t len;
+
+    if (af != AF_INET) {
+        return NULL;
+    }
+    memcpy(&addr, src, sizeof(addr));
+    text = inet_ntoa(addr);
+    if (text == NULL) {
+        return NULL;
+    }
+    len = strlen(text);
+    if (len + 1 > size) {
+        return NULL;
+    }
+    memcpy(dst, text, len + 1);
+    return dst;
+}
+
+#define inet_pton next_inet_pton
+#define inet_ntop next_inet_ntop
+#endif
+
