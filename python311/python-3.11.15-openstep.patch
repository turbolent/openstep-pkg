+        "call " symbol "\n\t" \
+        "addl $16, %%esp\n\t" \
+        "fstpl %0" \
+        : "=m" (result.d) \
+        : "r" (arg0.w.lo), "r" (arg0.w.hi), \
+          "r" (arg1.w.lo), "r" (arg1.w.hi) \
+        : "eax", "edx", "cc", "memory"); \
+    return result.d; \
+}
+
+NEXT_LIBM_UNARY(acos, "_acos")
+NEXT_LIBM_UNARY(asin, "_asin")
+NEXT_LIBM_UNARY(atan, "_atan")
+NEXT_LIBM_BINARY(atan2, "_atan2")
+NEXT_LIBM_UNARY(ceil, "_ceil")
+NEXT_LIBM_BINARY(copysign, "_copysign")
