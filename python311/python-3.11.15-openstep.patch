+double
+_Py_next_acosh(double x)
+{
+    return _Py_next_log(x + _Py_next_sqrt(x * x - 1.0));
+}
+
+double
+_Py_next_asinh(double x)
+{
+    double ax;
+
+    ax = x < 0.0 ? -x : x;
+    if (x < 0.0) {
+        return -_Py_next_log(ax + _Py_next_sqrt(ax * ax + 1.0));
+    }
+    return _Py_next_log(x + _Py_next_sqrt(x * x + 1.0));
+}
+
+double
+_Py_next_atanh(double x)
+{
+    return 0.5 * _Py_next_log((1.0 + x) / (1.0 - x));
+}
+
+double
+_Py_next_cbrt(double x)
+{
+    if (x < 0.0) {
+        return -_Py_next_pow(-x, 1.0 / 3.0);
+    }
+    return _Py_next_pow(x, 1.0 / 3.0);
+}
+
+double
+_Py_next_expm1(double x)
+{
+    return _Py_next_exp(x) - 1.0;
+}
+
+double
+_Py_next_log1p(double x)
+{
+    return _Py_next_log(1.0 + x);
+}
+
+double
+_Py_next_frexp(double x, int *e)
+{
+    next_double_words arg;
+    next_double_words result;
+    arg.d = x;
+    __asm__ volatile(
+        "pushl %2\n\t"
+        "pushl %4\n\t"
+        "pushl %3\n\t"
+        "call _frexp\n\t"
+        "addl $12, %%esp\n\t"
+        "fstpl %0"
+        : "=m" (result.d)
+        : "r" (arg.w.lo), "r" (e), "r" (arg.w.lo), "r" (arg.w.hi)
+        : "eax", "edx", "cc", "memory");
+    return result.d;
+}
+
+double
+_Py_next_ldexp(double x, int e)
+{
+    next_double_words arg;
+    next_double_words result;
+    arg.d = x;
+    __asm__ volatile(
+        "pushl %2\n\t"
+        "pushl %4\n\t"
+        "pushl %3\n\t"
+        "call _ldexp\n\t"
+        "addl $12, %%esp\n\t"
+        "fstpl %0"
+        : "=m" (result.d)
+        : "r" (arg.w.lo), "r" (e), "r" (arg.w.lo), "r" (arg.w.hi)
+        : "eax", "edx", "cc", "memory");
+    return result.d;
+}
+
+double
+_Py_next_modf(double x, double *iptr)
+{
+    next_double_words arg;
+    next_double_words result;
+    arg.d = x;
+    __asm__ volatile(
+        "pushl %2\n\t"
+        "pushl %4\n\t"
+        "pushl %3\n\t"
+        "call _modf\n\t"
+        "addl $12, %%esp\n\t"
+        "fstpl %0"
+        : "=m" (result.d)
+        : "r" (arg.w.lo), "r" (iptr), "r" (arg.w.lo), "r" (arg.w.hi)
+        : "eax", "edx", "cc", "memory");
+    return result.d;
+}
+
+double
+_Py_next_round(double x)
+{
+    if (x >= 0.0) {
+        return _Py_next_floor(x + 0.5);
+    }
+    return _Py_next_ceil(x - 0.5);
+}
