diff --git patch-2.6.1/Makefile.openstep patch-2.6.1/Makefile.openstep
new file mode 100644
index 0000000..fd74711
--- /dev/null
+++ patch-2.6.1/Makefile.openstep
@@ -0,0 +1,60 @@
+CC = cc
+CFLAGS = -g -O2
+CPPFLAGS = -I. -I./src -I./gl/lib -DHAVE_CONFIG_H -DENABLE_MERGE -Ded_PROGRAM=\"/bin/ed\"
+
+LIBOBJS = \
+	gl/lib/argmatch.o \
+	gl/lib/backupfile.o \
+	gl/lib/basename.o \
+	gl/lib/dirname.o \
+	gl/lib/stripslash.o \
+	gl/lib/error.o \
+	gl/lib/exitfail.o \
+	gl/lib/strndup.o \
+	gl/lib/strnlen.o \
+	gl/lib/getopt.o \
+	gl/lib/getopt1.o \
+	gl/lib/hash.o \
+	gl/lib/quote.o \
+	gl/lib/quotearg.o \
+	gl/lib/safe-write.o \
+	gl/lib/xmalloc.o \
+	gl/lib/xstrndup.o \
+	gl/lib/full-write.o
+
+OBJS = \
+	$(LIBOBJS) \
+	src/inp.o \
+	src/maketime.o \
+	src/merge.o \
+	src/partime.o \
+	src/patch.o \
+	src/pch.o \
+	src/quotesys.o \
+	src/util.o \
+	src/version.o
+
+.SUFFIXES: .c .o
+
+all: getopt.h stdbool.h src/patch
+
+getopt.h: gl/lib/getopt.hin
+	rm -f $@ $@-t
+	{ echo '/* DO NOT EDIT! GENERATED AUTOMATICALLY! */'; cat gl/lib/getopt.hin; } > $@-t
+	mv $@-t $@
+
+stdbool.h: gl/lib/stdbool.hin
+	rm -f $@ $@-t
+	{ echo '/* DO NOT EDIT! GENERATED AUTOMATICALLY! */'; sed -e 's/@HAVE__BOOL@/0/g' < gl/lib/stdbool.hin; } > $@-t
+	mv $@-t $@
+
+src/patch: $(OBJS)
+	$(CC) -o $@ $(OBJS)
+
+$(OBJS): config.h getopt.h stdbool.h
+
+.c.o:
+	$(CC) $(CPPFLAGS) $(CFLAGS) -c $< -o $@
+
+clean:
+	rm -f $(OBJS) src/patch getopt.h stdbool.h
