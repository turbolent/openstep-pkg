diff --git patch-2.6.1/gl/lib/strnlen.c patch-2.6.1/gl/lib/strnlen.c
new file mode 100644
index 0000000..1b107f1
--- /dev/null
+++ patch-2.6.1/gl/lib/strnlen.c
@@ -0,0 +1,12 @@
+/* Replacement strnlen for hosts that lack it. */
+
+#include <config.h>
+
+#include <string.h>
+
+size_t
+rpl_strnlen (const char *s, size_t maxlen)
+{
+  const void *end = memchr (s, '\0', maxlen);
+  return end ? (size_t) ((const char *) end - s) : maxlen;
+}
