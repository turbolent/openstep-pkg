+#ifdef NeXT
+extern char **environ;
+
+char *strdup (const char *string)
+{
+    char *copy;
+    size_t length;
+
+    length = strlen (string) + 1;
+    copy = malloc (length);
+    if (!copy)
+        return NULL;
+
+    memcpy (copy, string, length);
+    return copy;
+}
+
+int putenv (const char *string)
+{
+    char **ep;
+    char **new_environ;
+    char *entry_copy;
+    const char *name_end;
+    size_t name_len;
+    int env_count;
+
+    name_end = strchr (string, '=');
+    if (name_end)
+        name_len = (size_t)(name_end - string);
+    else
+        name_len = strlen (string);
+
+    ep = environ;
+    while (ep && *ep)
+    {
+        if (strncmp (*ep, string, name_len) == 0 && (*ep)[name_len] == '=')
+            break;
+        ep++;
+    }
+
+    if (!name_end)
+    {
+        if (!ep || !*ep)
+            return 0;
+
+        do
+        {
+            ep[0] = ep[1];
+            ep++;
+        } while (ep[0]);
+        return 0;
+    }
+
+    entry_copy = strdup (string);
+    if (!entry_copy)
+        return -1;
+
+    if (ep && *ep)
+    {
+        *ep = entry_copy;
+        return 0;
+    }
+
+    env_count = 0;
+    if (environ)
+    {
+        while (environ[env_count])
+            env_count++;
+    }
+
+    new_environ = malloc ((env_count + 2) * sizeof(*new_environ));
+    if (!new_environ)
+        return -1;
+
+    if (environ && env_count)
+        memcpy (new_environ, environ, env_count * sizeof(*new_environ));
+
+    new_environ[env_count] = entry_copy;
+    new_environ[env_count + 1] = NULL;
+    environ = new_environ;
+    return 0;
+}
+#endif
