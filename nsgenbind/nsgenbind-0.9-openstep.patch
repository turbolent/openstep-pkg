diff --git a/src/utils.c b/src/utils.c
index 85d26f26e..9e4108b33 100644
--- a/src/utils.c
+++ b/src/utils.c
@@ -11,12 +11,61 @@
 #include <stdbool.h>
 #include <errno.h>
 #include <stdlib.h>
+#ifdef NeXT
+#include <stdarg.h>
+#endif
+#ifdef NeXT
+extern int getpid(void);
+#else
 #include <sys/types.h>
 #include <unistd.h>
+#endif
 
 #include "options.h"
 #include "utils.h"
 
+#ifdef NeXT
+char *strdup(const char *s)
+{
+        size_t len;
+        char *copy;
+
+        len = strlen(s) + 1;
+        copy = malloc(len);
+        if (copy != NULL) {
+                memcpy(copy, s, len);
+        }
+        return copy;
+}
+
+int vsnprintf(char *str, size_t size, const char *format, va_list ap)
+{
+        char tmp[8192];
+        int ret;
+        size_t copy;
+
+        ret = vsprintf(tmp, format, ap);
+        if ((str != NULL) && (size != 0)) {
+                copy = (ret >= 0 && (size_t)ret < size) ?
+                        (size_t)ret : size - 1;
+                memcpy(str, tmp, copy);
+                str[copy] = 0;
+        }
+        return ret;
+}
+
+int snprintf(char *str, size_t size, const char *format, ...)
+{
+        va_list ap;
+        int ret;
+
+        va_start(ap, format);
+        ret = vsnprintf(str, size, format, ap);
+        va_end(ap);
+        return ret;
+}
+#endif
