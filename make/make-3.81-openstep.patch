 #include "dep.h"
 #include "debug.h"
 
+#ifdef NeXT
+extern char **environ;
+
+int
+putenv (const char *string)
+{
+  char **ep;
+  char **new_environ;
+  size_t name_len;
+  char *entry;
+  const char *name_end;
+  int count;
+  int i;
+
+  name_end = strchr (string, '=');
+  name_len = name_end == 0 ? strlen (string) : (size_t) (name_end - string);
+
+  for (ep = environ; ep != 0 && *ep != 0; ++ep)
+    if (strncmp (*ep, string, name_len) == 0 && (*ep)[name_len] == '=')
+      break;
+
+  if (name_end == 0)
+    {
+      if (ep == 0 || *ep == 0)
+        return 0;
+
+      do
+        {
+          ep[0] = ep[1];
+          ++ep;
+        }
+      while (ep[0] != 0);
+
+      return 0;
+    }
+
+  entry = xmalloc (strlen (string) + 1);
+  strcpy (entry, string);
+
+  if (ep != 0 && *ep != 0)
+    {
+      *ep = entry;
+      return 0;
+    }
+
+  count = 0;
+  if (environ != 0)
+    while (environ[count] != 0)
+      ++count;
+
+  new_environ = xmalloc ((count + 2) * sizeof (char *));
+  for (i = 0; i < count; ++i)
+    new_environ[i] = environ[i];
+  new_environ[count] = entry;
+  new_environ[count + 1] = 0;
+  environ = new_environ;
+
+  return 0;
+}
+#endif
