diff --git a/srclib/error.c b/srclib/error.c
index 535d8a2..15431aa 100644
--- a/srclib/error.c
+++ b/srclib/error.c
@@ -28,6 +28,13 @@
 #include <stdlib.h>
 #include <string.h>
 
+#ifdef NeXT
+# undef _GL_ATTRIBUTE_FORMAT_PRINTF
+# define _GL_ATTRIBUTE_FORMAT_PRINTF(a, b)
+# undef _GL_ARG_NONNULL
+# define _GL_ARG_NONNULL(a)
+#endif
+
 #if !_LIBC && ENABLE_NLS
 # include "gettext.h"
 # define _(msgid) gettext (msgid)
diff --git a/srclib/error.h b/srclib/error.h
index b24d6bf..ec68953 100644
--- a/srclib/error.h
+++ b/srclib/error.h
@@ -25,7 +25,7 @@
    We enable _GL_ATTRIBUTE_FORMAT only if these are supported too, because
    gnulib and libintl do '#define printf __printf__' when they override
    the 'printf' function.  */
-#if __GNUC__ > 2 || (__GNUC__ == 2 && __GNUC_MINOR__ >= 7)
+#if !defined NeXT && (__GNUC__ > 2 || (__GNUC__ == 2 && __GNUC_MINOR__ >= 7))
 # define _GL_ATTRIBUTE_FORMAT(spec) __attribute__ ((__format__ spec))
 #else
 # define _GL_ATTRIBUTE_FORMAT(spec) /* empty */
diff --git a/srclib/getprogname.c b/srclib/getprogname.c
index 82697d6..00828e6 100644
--- a/srclib/getprogname.c
+++ b/srclib/getprogname.c
@@ -75,6 +75,8 @@ getprogname (void)
   extern char *__progname;
   const char *p = __progname;
   return p && p[0] ? p : "?";
+# elif defined NeXT
+  return "?";
 # elif _AIX                                                 /* AIX */
   /* Idea by Bastien ROUCARIÈS,
      http://lists.gnu.org/archive/html/bug-gnulib/2010-12/msg00095.html
diff --git a/srclib/stddef.in.h b/srclib/stddef.in.h
index 5b496a6..918b228 100644
--- a/srclib/stddef.in.h
+++ b/srclib/stddef.in.h
@@ -90,7 +90,7 @@
    and the C11 standard allows this.  Work around this problem by
    using __alignof__ (which returns 8 for double) rather than _Alignof
    (which returns 4), and align each union member accordingly.  */
-# ifdef __GNUC__
+# if defined __GNUC__ && !defined NeXT
 #  define _GL_STDDEF_ALIGNAS(type) \
      __attribute__ ((__aligned__ (__alignof__ (type))))
 # else
