diff --git b/include/libcss/openstep.h b/include/libcss/openstep.h
new file mode 100644
index 0000000..f3a7fce
--- /dev/null
+++ b/include/libcss/openstep.h
@@ -0,0 +1,61 @@
+/*
+ * OPENSTEP compatibility definitions for systems without C99 headers.
+ */
+
+#ifndef libcss_openstep_h_
+#define libcss_openstep_h_
+
+#ifdef NeXT
+
+#ifndef __TARGET_ARCHITECTURE__
+#define __TARGET_ARCHITECTURE__ "i386"
+#endif
+
+/*
+ * GCC 3's preprocessor on OPENSTEP does not expand NeXT's ARCH_INCLUDE()
+ * string-concatenating include helper correctly.  These private machine
+ * headers are not needed for libcss' public dependency types.
+ */
+#ifndef _BSD_MACHINE_ENDIAN_H_
+#define _BSD_MACHINE_ENDIAN_H_
+#endif
+#ifndef _BSD_MACHINE_LABEL_T_H_
+#define _BSD_MACHINE_LABEL_T_H_
+#endif
+#ifndef _BSD_MACHINE_TYPES_H_
+#define _BSD_MACHINE_TYPES_H_
+#endif
+#ifndef _ANSI_MACHINE_LIMITS_H_
+#define _ANSI_MACHINE_LIMITS_H_
+#endif
+#ifndef _ANSI_MACHINE_LIMITS_H
+#define _ANSI_MACHINE_LIMITS_H
+#endif
+
+#include <libwapcaplet/libwapcaplet.h>
+
+#ifndef parserutils_openstep_h_
+#define parserutils_openstep_h_
+#ifndef OPENSTEP_C99_TYPES_DEFINED
+typedef signed short int16_t;
+typedef unsigned short uint16_t;
+typedef signed int int32_t;
+typedef signed long long int64_t;
+typedef unsigned long long uint64_t;
+#endif
+#endif
+
+#ifndef INT32_MAX
+#define INT32_MAX 2147483647
+#endif
+#ifndef UINT32_MAX
+#define UINT32_MAX 4294967295U
+#endif
+
+#ifndef restrict
+#define restrict
+#endif
+
+#endif
+
+#endif
