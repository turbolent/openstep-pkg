diff --git a/lib/curlx/wait.c b/lib/curlx/wait.c
index 4e10a82..91afaeb 100644
--- a/lib/curlx/wait.c
+++ b/lib/curlx/wait.c
@@ -40,6 +40,10 @@
 #include <dos.h>  /* delay() */
 #endif
 
+#if defined(NeXT) || defined(__NeXT__) || defined(__NeXT)
+extern int usleep(unsigned int useconds);
+#endif
+
 #include "timediff.h"
 #include "wait.h"
 
@@ -61,6 +65,10 @@
 int curlx_wait_ms(timediff_t timeout_ms)
 {
   int r = 0;
+#if defined(NeXT) || defined(__NeXT__) || defined(__NeXT)
+  timediff_t pending_ms;
+  unsigned int pending_us;
+#endif
 
   if(!timeout_ms)
     return 0;
@@ -78,6 +86,19 @@ int curlx_wait_ms(timediff_t timeout_ms)
     /* do not use ULONG_MAX, because that is equal to INFINITE */
 #endif
   Sleep((DWORD)timeout_ms);
+#elif defined(NeXT) || defined(__NeXT__) || defined(__NeXT)
+  pending_ms = timeout_ms;
+  while(pending_ms > 0) {
+    if(pending_ms > 1000) {
+      pending_us = 1000000U;
+      pending_ms -= 1000;
+    }
+    else {
+      pending_us = (unsigned int)pending_ms * 1000U;
+      pending_ms = 0;
+    }
+    (void)usleep(pending_us);
+  }
 #else
   /* avoid using poll() for this since it behaves incorrectly with no sockets
      on Apple operating systems */
