diff --git a/src/tool_getpass.c b/src/tool_getpass.c
index a92fb75..2ef99f3 100644
--- a/src/tool_getpass.c
+++ b/src/tool_getpass.c
@@ -32,6 +32,9 @@
 
 #ifdef HAVE_TERMIOS_H
 #  include <termios.h>
+#  if defined(NeXT) || defined(__NeXT__) || defined(__NeXT)
+#    include <sys/ioctl.h>
+#  endif
 #elif defined(HAVE_TERMIO_H)
 #  include <termio.h>
 #endif
@@ -140,10 +143,17 @@ static bool ttyecho(bool enable, int fd)
     /* disable echo by extracting the current 'withecho' mode and remove the
        ECHO bit and set back the struct */
 #ifdef HAVE_TERMIOS_H
+#if defined(NeXT) || defined(__NeXT__) || defined(__NeXT)
+    ioctl(fd, TIOCGETA, &withecho);
+    noecho = withecho;
+    noecho.c_lflag &= ~(tcflag_t)ECHO;
+    ioctl(fd, TIOCSETA, &noecho);
+#else
     tcgetattr(fd, &withecho);
     noecho = withecho;
     noecho.c_lflag &= ~(tcflag_t)ECHO;
     tcsetattr(fd, TCSANOW, &noecho);
+#endif
 #elif defined(HAVE_TERMIO_H)
     ioctl(fd, TCGETA, &withecho);
     noecho = withecho;
@@ -159,7 +169,11 @@ static bool ttyecho(bool enable, int fd)
   /* re-enable echo, assumes we disabled it before (and set the structs we
      now use to reset the terminal status) */
 #ifdef HAVE_TERMIOS_H
+#if defined(NeXT) || defined(__NeXT__) || defined(__NeXT)
+  ioctl(fd, TIOCSETAF, &withecho);
+#else
   tcsetattr(fd, TCSAFLUSH, &withecho);
+#endif
 #elif defined(HAVE_TERMIO_H)
   ioctl(fd, TCSETA, &withecho);
 #else
