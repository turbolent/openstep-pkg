diff --git b/openstep-compat.h b/openstep-compat.h
new file mode 100644
index 0000000..542ddd5
--- /dev/null
+++ b/openstep-compat.h
@@ -0,0 +1,381 @@
+#ifndef QUICKJS_OPENSTEP_COMPAT_H
+#define QUICKJS_OPENSTEP_COMPAT_H
+
+#if defined(NeXT) || defined(__NeXT__) || defined(__NeXT)
+
+#include <stdarg.h>
+#include <errno.h>
+#include <stdio.h>
+#include <stdlib.h>
+#include <string.h>
+#include <math.h>
+#include <time.h>
+#include <unistd.h>
+
+typedef long ssize_t;
+
+struct timespec {
+    long tv_sec;
+    long tv_nsec;
+};
+
+extern char **environ;
+extern char *getwd(char *);
+extern int usleep(unsigned int);
+
+#ifndef _SC_OPEN_MAX
+#define _SC_OPEN_MAX 4
+#endif
+#ifndef ENOSYS
+#define ENOSYS 78
+#endif
+#ifndef PATH_MAX
+#define PATH_MAX 4096
+#endif
+#ifndef CLOCKS_PER_SEC
+#define CLOCKS_PER_SEC 1000000
+#endif
+
+#undef WIFEXITED
+#undef WEXITSTATUS
+#undef WIFSIGNALED
+#undef WTERMSIG
+#define WIFEXITED(status) (((status) & 0177) == 0)
+#define WEXITSTATUS(status) (((status) >> 8) & 0xff)
+#define WIFSIGNALED(status) (((status) & 0177) != 0 && ((status) & 0177) != 0177)
+#define WTERMSIG(status) ((status) & 0177)
+
+#ifndef NAN
+#define NAN (0.0 / 0.0)
+#endif
+#ifndef INFINITY
+#define INFINITY HUGE_VAL
+#endif
+
+typedef void (*sighandler_t)(int);
+
+static int qjs_openstep_vsnprintf(char *str, size_t size,
+                                  const char *format, va_list ap)
+{
+    char tmpbuf[65536];
+    int rc;
+
+    rc = vsprintf(tmpbuf, format, ap);
+    if (size > 0) {
+        strncpy(str, tmpbuf, size - 1);
+        str[size - 1] = '\0';
+    }
+    return rc;
+}
+
+static int qjs_openstep_snprintf(char *str, size_t size,
+                                 const char *format, ...)
+{
+    va_list ap;
+    int rc;
+
+    va_start(ap, format);
+    rc = qjs_openstep_vsnprintf(str, size, format, ap);
+    va_end(ap);
+    return rc;
+}
+
+static char *qjs_openstep_strdup(const char *str)
+{
+    size_t len;
+    char *p;
+
+    len = strlen(str) + 1;
+    p = malloc(len);
+    if (p != NULL)
+        memcpy(p, str, len);
+    return p;
+}
+
+static double qjs_openstep_trunc(double d)
+{
+    return d < 0 ? ceil(d) : floor(d);
+}
+
+static double qjs_openstep_round(double d)
+{
+    return d < 0 ? ceil(d - 0.5) : floor(d + 0.5);
+}
+
+static double qjs_openstep_log2(double d)
+{
+    return log(d) / log(2.0);
+}
+
+static double qjs_openstep_cosh(double d)
+{
+    return (exp(d) + exp(-d)) / 2.0;
+}
+
+static double qjs_openstep_sinh(double d)
+{
+    return (exp(d) - exp(-d)) / 2.0;
+}
+
+static double qjs_openstep_tanh(double d)
+{
+    double e2x;
+
+    e2x = exp(2.0 * d);
+    return (e2x - 1.0) / (e2x + 1.0);
+}
+
+static double qjs_openstep_hypot(double a, double b)
+{
+    return sqrt(a * a + b * b);
+}
+
+static double qjs_openstep_acosh(double d)
+{
+    return log(d + sqrt(d - 1.0) * sqrt(d + 1.0));
+}
+
+static double qjs_openstep_asinh(double d)
+{
+    return log(d + sqrt(d * d + 1.0));
+}
+
+static double qjs_openstep_atanh(double d)
+{
+    return 0.5 * log((1.0 + d) / (1.0 - d));
+}
+
+static double qjs_openstep_expm1(double d)
+{
+    return exp(d) - 1.0;
+}
+
+static double qjs_openstep_log1p(double d)
+{
+    return log(1.0 + d);
+}
+
+static double qjs_openstep_cbrt(double d)
+{
+    if (d < 0)
+        return -pow(-d, 1.0 / 3.0);
+    return pow(d, 1.0 / 3.0);
+}
+
+static double qjs_openstep_fmin(double a, double b)
+{
+    if (a != a)
+        return b;
+    if (b != b)
+        return a;
+    return a < b ? a : b;
+}
+
+static double qjs_openstep_fmax(double a, double b)
+{
+    if (a != a)
+        return b;
+    if (b != b)
+        return a;
+    return a > b ? a : b;
+}
+
+static long qjs_openstep_lrint(double d)
+{
+    return (long)(d < 0 ? d - 0.5 : d + 0.5);
+}
+
+static int qjs_openstep_isnan(double d)
+{
+    return d != d;
+}
+
+static int qjs_openstep_isfinite(double d)
+{
+    return !qjs_openstep_isnan(d) &&
+           d <= 1.7976931348623157e+308 &&
+           d >= -1.7976931348623157e+308;
+}
+
+static int qjs_openstep_signbit(double d)
+{
+    union {
+        double d;
+        uint64_t u64;
+    } u;
+
+    u.d = d;
+    return (u.u64 >> 63) != 0;
+}
+
+static struct tm *qjs_openstep_localtime_r(const time_t *timep, struct tm *result)
+{
+    struct tm *tmp;
+
+    tmp = localtime(timep);
+    if (tmp == NULL)
+        return NULL;
+    *result = *tmp;
+    return result;
+}
+
+static char *qjs_openstep_getcwd(char *buf, size_t size)
+{
+    char tmp[PATH_MAX];
+
+    if (getwd(tmp) == NULL)
+        return NULL;
+    if (strlen(tmp) + 1 > size) {
+        errno = ERANGE;
+        return NULL;
+    }
+    strcpy(buf, tmp);
+    return buf;
+}
+
+static int qjs_openstep_setenv(const char *name, const char *value, int overwrite)
+{
+    char *entry;
+    char **new_environ;
+    size_t count, i;
+    size_t len;
+    size_t name_len;
+
+    if (!overwrite && getenv(name) != NULL)
+        return 0;
+    name_len = strlen(name);
+    len = strlen(name) + strlen(value) + 2;
+    entry = malloc(len);
+    if (entry == NULL)
+        return -1;
+    qjs_openstep_snprintf(entry, len, "%s=%s", name, value);
+    for (i = 0; environ[i] != NULL; i++) {
+        if (strncmp(environ[i], name, name_len) == 0 &&
+            environ[i][name_len] == '=') {
+            environ[i] = entry;
+            return 0;
+        }
+    }
+    count = i;
+    new_environ = malloc((count + 2) * sizeof(*new_environ));
+    if (new_environ == NULL)
+        return -1;
+    for (i = 0; i < count; i++)
+        new_environ[i] = environ[i];
+    new_environ[count] = entry;
+    new_environ[count + 1] = NULL;
+    environ = new_environ;
+    return 0;
+}
+
+static int qjs_openstep_unsetenv(const char *name)
+{
+    size_t len;
+    char **src, **dst;
+
+    len = strlen(name);
+    for (src = dst = environ; *src != NULL; src++) {
+        if (strncmp(*src, name, len) == 0 && (*src)[len] == '=')
+            continue;
+        *dst++ = *src;
+    }
+    *dst = NULL;
+    return 0;
+}
+
+static long qjs_openstep_sysconf(int name)
+{
+    if (name == _SC_OPEN_MAX)
+        return 256;
+    errno = EINVAL;
+    return -1;
+}
+
+static int qjs_openstep_waitpid(int pid, int *status, int options)
+{
+    extern int wait4(int, int *, int, void *);
+
+    return wait4(pid, status, options, NULL);
+}
+
+static int qjs_openstep_tcgetattr(int fd, void *termios_p)
+{
+    (void)fd;
+    (void)termios_p;
+    errno = ENOSYS;
+    return -1;
+}
+
+static int qjs_openstep_tcsetattr(int fd, int optional_actions, const void *termios_p)
+{
+    (void)fd;
+    (void)optional_actions;
+    (void)termios_p;
+    errno = ENOSYS;
+    return -1;
+}
+
+static int qjs_openstep_nanosleep(const struct timespec *req,
+                                  struct timespec *rem)
+{
+    unsigned int usec;
+
+    (void)rem;
+    usec = (unsigned int)(req->tv_sec * 1000000 + req->tv_nsec / 1000);
+    return usleep(usec);
+}
+
+static char *qjs_openstep_realpath(const char *path, char *buf)
+{
+    char cwd_buf[PATH_MAX];
+
+    if (path[0] == '/') {
+        strncpy(buf, path, PATH_MAX - 1);
+        buf[PATH_MAX - 1] = '\0';
+        return buf;
+    }
+    if (qjs_openstep_getcwd(cwd_buf, sizeof(cwd_buf)) == NULL)
+        return NULL;
+    strncpy(buf, cwd_buf, PATH_MAX - 1);
+    buf[PATH_MAX - 1] = '\0';
+    strncat(buf, "/", PATH_MAX - strlen(buf) - 1);
+    strncat(buf, path, PATH_MAX - strlen(buf) - 1);
+    return buf;
+}
+
+#define snprintf qjs_openstep_snprintf
+#define vsnprintf qjs_openstep_vsnprintf
+#define strdup qjs_openstep_strdup
+#define trunc qjs_openstep_trunc
+#define round qjs_openstep_round
+#define log2 qjs_openstep_log2
+#define cosh qjs_openstep_cosh
+#define sinh qjs_openstep_sinh
+#define tanh qjs_openstep_tanh
+#define hypot qjs_openstep_hypot
+#define acosh qjs_openstep_acosh
+#define asinh qjs_openstep_asinh
+#define atanh qjs_openstep_atanh
+#define expm1 qjs_openstep_expm1
+#define log1p qjs_openstep_log1p
+#define cbrt qjs_openstep_cbrt
+#define fmin qjs_openstep_fmin
+#define fmax qjs_openstep_fmax
+#define lrint qjs_openstep_lrint
+#define isnan qjs_openstep_isnan
+#define isfinite qjs_openstep_isfinite
+#define signbit qjs_openstep_signbit
+#define localtime_r qjs_openstep_localtime_r
+#define getcwd qjs_openstep_getcwd
+#define setenv qjs_openstep_setenv
+#define unsetenv qjs_openstep_unsetenv
+#define sysconf qjs_openstep_sysconf
+#define waitpid qjs_openstep_waitpid
+#define tcgetattr qjs_openstep_tcgetattr
+#define tcsetattr qjs_openstep_tcsetattr
+#define nanosleep qjs_openstep_nanosleep
+#define realpath qjs_openstep_realpath
+
+#endif
+
+#endif
