+#ifdef NeXT
+static char *nsfb_strdup(const char *s)
+{
+    size_t len;
+    char *copy;
+
+    len = strlen(s) + 1;
+    copy = malloc(len);
+    if (copy != NULL) {
+        memcpy(copy, s, len);
+    }
+
+    return copy;
+}
+#define strdup nsfb_strdup
+#endif
