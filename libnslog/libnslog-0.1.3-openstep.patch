 }
 
+struct nslog_text_parser {
+	const char *input;
+};
+
+static void nslog__skip_ws(struct nslog_text_parser *parser)
+{
+	while (*parser->input == ' ' || *parser->input == '\t')
+		parser->input++;
+}
+
+static bool nslog__accept_char(struct nslog_text_parser *parser, char ch)
+{
+	nslog__skip_ws(parser);
+	if (*parser->input != ch)
+		return false;
+	parser->input++;
+	return true;
+}
+
+static bool nslog__accept_word(struct nslog_text_parser *parser,
+			       const char *word)
+{
+	const char *p = parser->input;
+	const char *w = word;
+
+	nslog__skip_ws(parser);
+	p = parser->input;
+	while (*w != '\0') {
+		if (*p != *w)
+			return false;
+		p++;
+		w++;
+	}
+	parser->input = p;
+	return true;
+}
+
+static char *nslog__read_pattern(struct nslog_text_parser *parser)
+{
+	const char *start;
+	const char *end;
+	char *ret;
+	int len;
+
+	nslog__skip_ws(parser);
+	start = parser->input;
+	end = start;
+	while (*end != '\0' &&
+	       *end != ' ' &&
+	       *end != '\t' &&
+	       *end != ':' &&
+	       *end != '|' &&
+	       *end != '&' &&
+	       *end != ')' &&
+	       *end != '^' &&
+	       *end != '!')
+		end++;
+
+	if (end == start)
+		return NULL;
+
+	len = end - start;
+	ret = malloc(len + 1);
+	if (ret == NULL)
+		return NULL;
+
+	memcpy(ret, start, len);
+	ret[len] = '\0';
+	parser->input = end;
+	return ret;
+}
+
+static bool nslog__read_level(struct nslog_text_parser *parser,
+			      nslog_level *level)
+{
+	const char *start;
+	const char *end;
+	int len;
+
+	nslog__skip_ws(parser);
+	start = parser->input;
+	end = start;
+	while ((*end >= 'A' && *end <= 'Z') || (*end >= '0' && *end <= '9'))
+		end++;
+
+	len = end - start;
+	if (len == 9 && strncmp(start, "DEEPDEBUG", len) == 0)
+		*level = NSLOG_LEVEL_DEEPDEBUG;
+	else if (len == 6 && strncmp(start, "DDEBUG", len) == 0)
+		*level = NSLOG_LEVEL_DEEPDEBUG;
+	else if (len == 2 && strncmp(start, "DD", len) == 0)
+		*level = NSLOG_LEVEL_DEEPDEBUG;
+	else if (len == 5 && strncmp(start, "DEBUG", len) == 0)
+		*level = NSLOG_LEVEL_DEBUG;
+	else if (len == 3 && strncmp(start, "DBG", len) == 0)
+		*level = NSLOG_LEVEL_DEBUG;
+	else if (len == 7 && strncmp(start, "VERBOSE", len) == 0)
+		*level = NSLOG_LEVEL_VERBOSE;
+	else if (len == 4 && strncmp(start, "CHAT", len) == 0)
+		*level = NSLOG_LEVEL_VERBOSE;
+	else if (len == 4 && strncmp(start, "INFO", len) == 0)
+		*level = NSLOG_LEVEL_INFO;
+	else if (len == 7 && strncmp(start, "WARNING", len) == 0)
+		*level = NSLOG_LEVEL_WARNING;
+	else if (len == 4 && strncmp(start, "WARN", len) == 0)
+		*level = NSLOG_LEVEL_WARNING;
+	else if (len == 5 && strncmp(start, "ERROR", len) == 0)
+		*level = NSLOG_LEVEL_ERROR;
+	else if (len == 3 && strncmp(start, "ERR", len) == 0)
+		*level = NSLOG_LEVEL_ERROR;
+	else if (len == 8 && strncmp(start, "CRITICAL", len) == 0)
+		*level = NSLOG_LEVEL_CRITICAL;
+	else if (len == 4 && strncmp(start, "CRIT", len) == 0)
+		*level = NSLOG_LEVEL_CRITICAL;
+	else
+		return false;
+
+	parser->input = end;
+	return true;
+}
+
+static nslog_filter_t *nslog__parse_filter(struct nslog_text_parser *parser);
+
+static nslog_filter_t *nslog__parse_basic_filter(struct nslog_text_parser *parser)
+{
+	const char *saved;
+	nslog_filter_t *filter = NULL;
+	char *pattern = NULL;
+	nslog_level level;
+
+	saved = parser->input;
+	if (nslog__accept_word(parser, "level:") ||
+	    nslog__accept_word(parser, "lvl:")) {
+		if (!nslog__read_level(parser, &level))
+			goto fail;
+		if (nslog_filter_level_new(level, &filter) != NSLOG_NO_ERROR)
+			goto fail;
+		return filter;
+	}
+
+	parser->input = saved;
+	if (nslog__accept_word(parser, "cat:") ||
+	    nslog__accept_word(parser, "category:")) {
+		pattern = nslog__read_pattern(parser);
+		if (pattern == NULL)
+			goto fail;
+		if (nslog_filter_category_new(pattern, &filter) != NSLOG_NO_ERROR)
+			goto fail;
+		free(pattern);
+		return filter;
+	}
+
+	parser->input = saved;
+	if (nslog__accept_word(parser, "file:") ||
+	    nslog__accept_word(parser, "filename:")) {
+		pattern = nslog__read_pattern(parser);
+		if (pattern == NULL)
+			goto fail;
+		if (nslog_filter_filename_new(pattern, &filter) != NSLOG_NO_ERROR)
+			goto fail;
+		free(pattern);
+		return filter;
+	}
+
+	parser->input = saved;
+	if (nslog__accept_word(parser, "dir:") ||
+	    nslog__accept_word(parser, "dirname:")) {
+		pattern = nslog__read_pattern(parser);
+		if (pattern == NULL)
+			goto fail;
+		if (nslog_filter_dirname_new(pattern, &filter) != NSLOG_NO_ERROR)
+			goto fail;
+		free(pattern);
+		return filter;
+	}
+
+	parser->input = saved;
+	if (nslog__accept_word(parser, "func:") ||
+	    nslog__accept_word(parser, "funcname:")) {
+		pattern = nslog__read_pattern(parser);
+		if (pattern == NULL)
+			goto fail;
+		if (nslog_filter_funcname_new(pattern, &filter) != NSLOG_NO_ERROR)
+			goto fail;
+		free(pattern);
+		return filter;
+	}
+
+fail:
+	free(pattern);
+	parser->input = saved;
+	return NULL;
+}
+
+static nslog_filter_t *nslog__parse_filter(struct nslog_text_parser *parser)
+{
+	nslog_filter_t *left = NULL;
+	nslog_filter_t *right = NULL;
+	nslog_filter_t *ret = NULL;
+	const char *saved;
+	char op = '\0';
+
+	nslog__skip_ws(parser);
+	if (nslog__accept_char(parser, '!')) {
+		left = nslog__parse_filter(parser);
+		if (left == NULL)
+			return NULL;
+		if (nslog_filter_not_new(left, &ret) != NSLOG_NO_ERROR)
+			ret = NULL;
+		nslog_filter_unref(left);
+		return ret;
+	}
+
+	saved = parser->input;
+	if (nslog__accept_char(parser, '(')) {
+		left = nslog__parse_filter(parser);
+		if (left == NULL)
+			goto fail;
+
+		nslog__skip_ws(parser);
+		if (parser->input[0] == '&' && parser->input[1] == '&') {
+			parser->input += 2;
+			op = '&';
+		} else if (parser->input[0] == '|' && parser->input[1] == '|') {
+			parser->input += 2;
+			op = '|';
+		} else if (parser->input[0] == '^') {
+			parser->input++;
+			op = '^';
+		} else {
+			goto fail;
+		}
+
+		right = nslog__parse_filter(parser);
+		if (right == NULL)
+			goto fail;
+		if (!nslog__accept_char(parser, ')'))
+			goto fail;
+
+		if (op == '&') {
+			if (nslog_filter_and_new(left, right, &ret) != NSLOG_NO_ERROR)
+				ret = NULL;
+		} else if (op == '|') {
+			if (nslog_filter_or_new(left, right, &ret) != NSLOG_NO_ERROR)
+				ret = NULL;
+		} else {
+			if (nslog_filter_xor_new(left, right, &ret) != NSLOG_NO_ERROR)
+				ret = NULL;
+		}
+		nslog_filter_unref(left);
+		nslog_filter_unref(right);
+		return ret;
+	}
+	parser->input = saved;
+
+	return nslog__parse_basic_filter(parser);
+
+fail:
+	nslog_filter_unref(left);
+	nslog_filter_unref(right);
+	parser->input = saved;
+	return NULL;
+}
+
 nslog_error nslog_filter_from_text(const char *input,
 				   nslog_filter_t **output)
 {
-	int ret;
-	YY_BUFFER_STATE buffer = filter__scan_string((char *)input);
-	filter_push_buffer_state(buffer);
-	ret = filter_parse(output);
-	filter_lex_destroy();
-	switch (ret) {
-	case 0:
-		return NSLOG_NO_ERROR;
-	case 2:
-		return NSLOG_NO_MEMORY;
+	struct nslog_text_parser parser;
+	nslog_filter_t *filter;
+
+	parser.input = input;
+	filter = nslog__parse_filter(&parser);
+	nslog__skip_ws(&parser);
+	if (filter == NULL || *parser.input != '\0') {
+		nslog_filter_unref(filter);
+		*output = NULL;
+		return NSLOG_PARSE_ERROR;
 	}
-	return NSLOG_PARSE_ERROR;
+
+	*output = filter;
+	return NSLOG_NO_ERROR;
 }
