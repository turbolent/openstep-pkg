+static void nslog__log_corked_string(nslog_entry_context_t *ctx,
+				     int measured_len,
+				     const char *message)
+{
+	struct nslog_cork_chain *newcork;
+
+	newcork = calloc(sizeof(struct nslog_cork_chain) + measured_len + 1, 1);
+	if (newcork == NULL) {
+		/* Wow, something went wrong */
+		return;
+	}
+	newcork->context = *ctx;
+	memcpy(newcork->message, message, measured_len + 1);
+	if (nslog__cork_chain == NULL) {
+		nslog__cork_chain = nslog__cork_chain_last = newcork;
+	} else {
+		nslog__cork_chain_last->next = newcork;
+		nslog__cork_chain_last = newcork;
+	}
+}
