diff --git a/gcc/config/nextstep.h b/gcc/config/nextstep.h
index 76e1a35..d1841b1 100644
--- a/gcc/config/nextstep.h
+++ b/gcc/config/nextstep.h
@@ -234,6 +234,17 @@ Boston, MA 02111-1307, USA.  */
 
 #define EH_FRAME_SECTION_ASM_OP "\t.section __TEXT,__eh_frame,regular"
 
+/* GCC 2.95.3 is used to bootstrap this target, and it does not provide
+   the DWARF2 unwinder builtins needed by GCC 3's unwind-dw2 runtime.  */
+#undef DWARF2_UNWIND_INFO
+#define DWARF2_UNWIND_INFO 0
+
+/* GCC 3's Mach-O crtstuff unconditionally references frame-registration
+   helpers whenever EH_FRAME_SECTION_ASM_OP is defined.  OPENSTEP uses the
+   stock libc and a reduced libgcc runtime here, so disable .eh_frame
+   registration on this target entirely.  */
+#undef EH_FRAME_SECTION_ASM_OP
+
 /* Don't output a .file directive.  That is only used by the assembler for
    error reporting.  */
 #undef	ASM_FILE_START
diff --git a/gcc/crtstuff.c b/gcc/crtstuff.c
