#!/bin/sh

set -e

CC="$ROOT_DIR/usr/local/bin/gcc"
SRC=/tmp/pkg-gcc3-$$.c
BIN=/tmp/pkg-gcc3-$$

[ -x "$CC" ]
/bin/rm -f "$SRC" "$BIN"

cat > "$SRC" <<'EOF'
#include <stdio.h>

int main(void)
{
    puts("ok");
    return 0;
}
EOF

"$CC" "$SRC" -o "$BIN"
value=`"$BIN"`
[ "$value" = ok ]

/bin/rm -f "$SRC" "$BIN"
