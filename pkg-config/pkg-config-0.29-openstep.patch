 #endif
 #include <time.h>
+#ifdef NeXT
+struct timespec { long tv_sec; long tv_nsec; };
+static int openstep_nanosleep (req, rem)
+struct timespec *req;
+struct timespec *rem;
+{
+  struct timeval tv;
+  tv.tv_sec = req->tv_sec;
+  tv.tv_usec = req->tv_nsec / 1000;
+  return select (0, 0, 0, 0, &tv);
+}
+#define nanosleep openstep_nanosleep
+#endif
