diff --git b/include/nsgif_openstep.h b/include/nsgif_openstep.h
new file mode 100644
index 0000000..2e061b7
--- /dev/null
+++ b/include/nsgif_openstep.h
@@ -0,0 +1,41 @@
+/*
+ * OPENSTEP compatibility for public LibNSGIF headers.
+ *
+ * OPENSTEP 4.2 does not provide the C99 integer or boolean headers used by
+ * LibNSGIF.  Keep the fallback narrow so hosted users still get the native
+ * headers everywhere else.
+ */
+
+#ifndef NSGIF_OPENSTEP_H
+#define NSGIF_OPENSTEP_H
+
+#ifdef NeXT
+
+typedef unsigned char uint8_t;
+typedef unsigned short uint16_t;
+typedef unsigned int uint32_t;
+
+#ifndef __cplusplus
+typedef unsigned char bool;
+#ifndef true
+#define true 1
+#endif
+#ifndef false
+#define false 0
+#endif
+#define __bool_true_false_are_defined 1
+#endif
+
+#ifndef UINT32_MAX
+#define UINT32_MAX 4294967295U
+#endif
+
+#else
+
+#include <stdint.h>
+#include <stdbool.h>
+#include <inttypes.h>
+
+#endif
+
+#endif
