+#ifdef NeXT
+char *
+strdup(const char *src)
+
+{
+    size_t len;
+    char *copy;
+
+    len = strlen(src) + 1;
+    copy = (char *)malloc(len);
+    if (copy != NULL)
+    {
+	memcpy(copy, src, len);
+    }
+    return(copy);
+}
+
+int
+vsnprintf(char *str, size_t size, const char *fmt, va_list ap)
+
+{
+    char buffer[4096];
+    int len;
+
+    len = vsprintf(buffer, fmt, ap);
+    if (size != 0)
+    {
+	size_t copy_len;
+
+	copy_len = (size_t)len;
+	if (copy_len >= size)
+	{
+	    copy_len = size - 1;
+	}
+	memcpy(str, buffer, copy_len);
+	str[copy_len] = '\0';
+    }
+    return(len);
+}
+
+int
+snprintf(char *str, size_t size, const char *fmt, ...)
+
+{
+    int len;
+    va_list ap;
+
+    va_start(ap, fmt);
+    len = vsnprintf(str, size, fmt, ap);
+    va_end(ap);
+    return(len);
+}
