+static int hubbub_ascii_tolower(int c)
+{
+	if (c >= 'A' && c <= 'Z')
+		return c + ('a' - 'A');
+
+	return c;
+}
+
+static int hubbub_ascii_strncasecmp(const char *a, const char *b, size_t len)
+{
+	size_t i;
+
+	for (i = 0; i < len; i++) {
+		int ca = hubbub_ascii_tolower((unsigned char) a[i]);
+		int cb = hubbub_ascii_tolower((unsigned char) b[i]);
+
+		if (ca != cb)
+			return ca - cb;
+	}
+
+	return 0;
+}
+
+static const struct element_type_map *
+hubbub_element_type_generated_lookup(const char *str, size_t len)
+{
+	size_t i;
+
+	for (i = 0; i < sizeof(wordlist) / sizeof(wordlist[0]); i++) {
+		const char *name = wordlist[i].name;
+		size_t name_len = strlen(name);
+
+		if (name_len == len && hubbub_ascii_strncasecmp(name, str, len) == 0)
+			return &wordlist[i];
+	}
+
+	return NULL;
+}
