diff --git a/misc.c b/misc.c
index e3fdd50..463ee4d 100644
--- a/misc.c
+++ b/misc.c
@@ -34,6 +34,23 @@
 #include "flexdef.h"
 #include "tables.h"
 
+#ifdef NeXT
+#undef snprintf
+int flex_next_snprintf(char *str, size_t size, const char *format, ...)
+{
+	va_list ap;
+	int ret;
+
+	va_start(ap, format);
+	ret = vsprintf(str, format, ap);
+	va_end(ap);
+	if (size > 0)
+		str[size - 1] = '\0';
+	return ret;
+}
+#define snprintf flex_next_snprintf
+#endif
+
 #define CMD_IF_TABLES_SER    "%if-tables-serialization"
 #define CMD_TABLES_YYDMAP    "%tables-yydmap"
