diff --git a/regex.c b/regex.c
index e12cf65..1e46f68 100644
--- a/regex.c
+++ b/regex.c
@@ -27,6 +27,101 @@
 static const char* REGEXP_LINEDIR = "^#line ([[:digit:]]+) \"(.*)\"";
 static const char* REGEXP_BLANK_LINE = "^[[:space:]]*$";
 
+#ifdef NeXT
+#define FLEX_NEXT_REGEX_LINEDIR 1
+#define FLEX_NEXT_REGEX_BLANK_LINE 2
+
+int regcomp(regex_t *preg, const char *regex, int cflags)
+{
+	(void)cflags;
+
+	if (strcmp(regex, REGEXP_LINEDIR) == 0) {
+		preg->kind = FLEX_NEXT_REGEX_LINEDIR;
+		return 0;
+	}
+	if (strcmp(regex, REGEXP_BLANK_LINE) == 0) {
+		preg->kind = FLEX_NEXT_REGEX_BLANK_LINE;
+		return 0;
+	}
+
+	preg->kind = 0;
+	return 1;
+}
+
+int regexec(const regex_t *preg, const char *string, size_t nmatch,
+	    regmatch_t pmatch[], int eflags)
+{
+	const char *p;
+	const char *digits;
+	const char *name;
+	const char *end;
+
+	(void)eflags;
+
+	if (preg->kind == FLEX_NEXT_REGEX_BLANK_LINE) {
+		for (p = string; *p != '\0'; p++) {
+			if (*p != ' ' && *p != '\t' && *p != '\r' && *p != '\n')
+				return 1;
+		}
+		return 0;
+	}
+
+	if (preg->kind != FLEX_NEXT_REGEX_LINEDIR)
+		return 1;
+
+	if (strncmp(string, "#line ", 6) != 0)
+		return 1;
+	digits = string + 6;
+	p = digits;
+	while (*p >= '0' && *p <= '9')
+		p++;
+	if (p == digits || *p != ' ' || p[1] != '"')
+		return 1;
+	name = p + 2;
+	end = name;
+	while (*end != '\0' && *end != '"')
+		end++;
+	if (*end != '"')
+		return 1;
+
+	if (nmatch > 0 && pmatch != NULL) {
+		pmatch[0].rm_so = 0;
+		pmatch[0].rm_eo = (int)(end - string + 1);
+	}
+	if (nmatch > 1 && pmatch != NULL) {
+		pmatch[1].rm_so = (int)(digits - string);
+		pmatch[1].rm_eo = (int)(p - string);
+	}
+	if (nmatch > 2 && pmatch != NULL) {
+		pmatch[2].rm_so = (int)(name - string);
+		pmatch[2].rm_eo = (int)(end - string);
+	}
+
+	return 0;
+}
+
+size_t regerror(int errcode, const regex_t *preg, char *errbuf,
+		size_t errbuf_size)
+{
+	const char *msg = "unsupported regular expression";
+	size_t len;
+
+	(void)errcode;
+	(void)preg;
+
+	len = strlen(msg);
+	if (errbuf != NULL && errbuf_size > 0) {
+		size_t copy_len = len;
+		if (copy_len >= errbuf_size)
+			copy_len = errbuf_size - 1;
+		memcpy(errbuf, msg, copy_len);
+		errbuf[copy_len] = '\0';
+	}
+
+	return len;
+}
+#endif
+
 regex_t regex_linedir; /**< matches line directives */
 regex_t regex_blank_line; /**< matches blank lines */
 
